---
import BaseLayout from '@layouts/BaseLayout.astro';

const modules = [
  { slug: 'fundamentos-python', title: 'Fundamentos Python', description: 'Variables, funciones, estructuras de datos y POO esencial' },
  { slug: 'apis-fastapi', title: 'APIs con FastAPI', description: 'Crea APIs REST profesionales con validación y autenticación' },
  { slug: 'github-actions', title: 'GitHub Actions', description: 'Automatiza CI/CD para tus proyectos Python' },
  { slug: 'python-n8n', title: 'Python + n8n', description: 'Automatiza workflows integrando Python con n8n' },
  { slug: 'python-docker', title: 'Python + Docker', description: 'Conteneriza tus aplicaciones Python para producción' },
  { slug: 'proyecto-integrador', title: 'Proyecto Integrador', description: 'Combina API, Docker, GitHub Actions y n8n' },
];
---
<BaseLayout title="Módulos" description="Lista de módulos disponibles">
  <div id="modules-top" class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Módulos</h1>
    <div class="grid gap-4 sm:grid-cols-2">
      {modules.map((m) => (
        <a href={`${import.meta.env.BASE_URL}modules/${m.slug}`} class="block p-6 bg-white rounded-xl border-2 border-gray-200 hover:border-blue-500 transition">
          <h3 class="font-bold text-lg">{m.title}</h3>
          <p class="text-sm text-gray-600 mt-2">{m.description}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- Floating mobile back-to-top button -->
  <button id="modules-back-to-top" aria-label="Volver arriba" class="fixed bottom-6 right-4 z-50 md:hidden w-12 h-12 bg-blue-600 text-white rounded-full shadow-lg flex items-center justify-center transition-opacity duration-200 opacity-0 pointer-events-none">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
  </button>

  <script>
    (function(){
      const btn = document.getElementById('modules-back-to-top');
      const top = document.getElementById('modules-top');
      if(!btn || !top) return;
      const showAfter = 200;
      const toggle = () => {
        if(window.scrollY > showAfter) {
          btn?.classList.remove('opacity-0','pointer-events-none');
        } else {
          btn?.classList.add('opacity-0','pointer-events-none');
        }
      };
      window.addEventListener('scroll', toggle, { passive: true });
      btn.addEventListener('click', ()=> top.scrollIntoView({ behavior: 'smooth' }));
      // initial check
      toggle();
    })();
  </script>

</BaseLayout>
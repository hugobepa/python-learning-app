---
import BaseLayout from '@layouts/BaseLayout.astro';

const modules = [
  { slug: 'fundamentos-python', title: 'Fundamentos Python', description: 'Variables, funciones, estructuras de datos y POO esencial' },
  { slug: 'apis-fastapi', title: 'APIs con FastAPI', description: 'Crea APIs REST profesionales con validación y autenticación' },
  { slug: 'github-actions', title: 'GitHub Actions', description: 'Automatiza CI/CD para tus proyectos Python' },
  { slug: 'python-n8n', title: 'Python + n8n', description: 'Automatiza workflows integrando Python con n8n' },
  { slug: 'python-docker', title: 'Python + Docker', description: 'Conteneriza tus aplicaciones Python para producción' },
  { slug: 'proyecto-integrador', title: 'Proyecto Integrador', description: 'Combina API, Docker, GitHub Actions y n8n' },
];
---
<BaseLayout title="Módulos" description="Lista de módulos disponibles">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Módulos</h1>
    <div class="grid gap-4 sm:grid-cols-2">
      {modules.map((m) => (
        <a href={`/modules/${m.slug}`} class="block p-6 bg-white rounded-xl border-2 border-gray-200 hover:border-blue-500 transition">
          <h3 class="font-bold text-lg">{m.title}</h3>
          <p class="text-sm text-gray-600 mt-2">{m.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
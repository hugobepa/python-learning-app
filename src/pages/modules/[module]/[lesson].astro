---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export interface PathInfo {
  params: { module: string; lesson: string };
}

export async function getStaticPaths() {
  const modules = ['fundamentos-python', 'apis-fastapi', 'github-actions', 'python-n8n', 'python-docker', 'proyecto-integrador'];
  const paths: PathInfo[] = [];
  for (const m of modules) {
    for (let i = 1; i <= 6; i++) {
      paths.push({ params: { module: m, lesson: i.toString() } });
    }
  }
  return paths;
}

const { module, lesson } = Astro.params as { module: string; lesson: string };

const lessonData: Record<string, Record<string, { title: string; content: string }>> = {
  'fundamentos-python': {
    '1': { title: 'Instalación y Entorno', content: '<p>Contenido de la lección 1</p>' }
  }
};

const data = (lessonData[module]?.[lesson]) ?? { title: `Lección ${lesson}`, content: 'Contenido no disponible' };

const prevLesson = Math.max(1, parseInt(lesson) - 1).toString();
const nextLesson = (parseInt(lesson) + 1).toString();
---

<BaseLayout title={data.title} description="Lección del curso">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <a href={`/modules/${module}`} class="text-blue-600 hover:underline mb-4 inline-block">← Volver al módulo</a>
    
    <h1 class="text-3xl font-bold mb-6">{data.title}</h1>
    
    <article class="prose prose-slate max-w-none bg-white p-8 rounded-xl border">
      <div set:html={data.content} />
    </article>
    
    <div class="mt-8 pt-8 border-t flex justify-between">
      <a href={`/modules/${module}/${prevLesson}`} class="text-gray-600 hover:text-gray-900">← Anterior</a>
      <a href={`/modules/${module}/${nextLesson}`} class="text-blue-600 hover:text-blue-800">Siguiente →</a>
    </div>
  </div>
</BaseLayout>




---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export interface Props {
  module: string;
  lesson: string;
}

export async function getStaticPaths() {
  const modules = ['fundamentos-python', 'apis-fastapi', 'github-actions', 'python-n8n', 'python-docker', 'proyecto-integrador'];
  const paths = [];
  
  modules.forEach(module => {
    for (let i = 1; i <= 6; i++) {
      paths.push({
        params: { module, lesson: i.toString() }
      });
    }
  });
  
  return paths;
}

const { module, lesson } = Astro.props;

const lessonData: Record<string, Record<string, { title: string; content: string }>> = {
  'fundamentos-python': {
    '1': {
      title: 'Instalación y Entorno',
      content: `
## 🎯 Objetivos de Aprendizaje

Al finalizar esta lección podrás:
1. ✅ Instalar Python 3.12+ y verificar la instalación
2. ✅ Crear entornos virtuales para cada proyecto
3. ✅ Configurar tu editor de código (VS Code)

---

## 📚 Teoría Esencial

### ¿Por qué Entornos Virtuales?

| Sin Entorno Virtual | Con Entorno Virtual |
|---------------------|---------------------|
| Dependencias globales | Dependencias aisladas |
| Conflictos de versión | Versiones por proyecto |
| Difícil de reproducir | Fácil con requirements.txt |

---

## 💻 Ejemplo Guiado

### Ejemplo Junior

\`\`\`bash
# Crear entorno virtual
python -m venv .venv

# Activar (Windows PowerShell)
.venv\\Scripts\\Activate.ps1

# Activar (macOS/Linux)
source .venv/bin/activate

# Instalar paquete
pip install fastapi
\`\`\`

### Ejemplo Senior

\`\`\`bash
# Crear con versión específica
python3.12 -m venv .venv

# Activar y verificar
source .venv/bin/activate
which python
\`\`\`

---

## 🎮 Ejercicio Práctico

**Reto:** Configura tu primer proyecto Python

1. Crea una carpeta \`python-curso\`
2. Dentro, crea un entorno virtual \`.venv\`
3. Actívalo e instala \`fastapi\`
4. Crea \`src/main.py\` con un print
5. Ejecútalo

---

## ✅ Check de Comprensión

1. ¿Qué comando crea un entorno virtual?
   - \`python -m venv .venv\` ✅

2. ¿Por qué NO se sube \`.venv\` a Git?
   - Es específico de cada sistema ✅
`

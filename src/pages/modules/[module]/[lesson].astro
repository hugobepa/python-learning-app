---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export interface PathInfo {
  params: { module: string; lesson: string };
}

export async function getStaticPaths() {
  const modules = ['fundamentos-python', 'apis-fastapi', 'github-actions', 'python-n8n', 'python-docker', 'proyecto-integrador'];
  const paths: PathInfo[] = [];
  for (const m of modules) {
    for (let i = 1; i <= 6; i++) {
      paths.push({ params: { module: m, lesson: i.toString() } });
    }
  }
  return paths;
}

const { module, lesson } = Astro.params as { module: string; lesson: string };

// Build a map of available MDX lesson files under /src/content using an eager glob import.
const mdxFiles = import.meta.glob('/src/content/**/*.mdx', { eager: true }) as Record<string, any>;

type MDXEntry = { component: any; frontmatter?: Record<string, any> };
const mdxMap: Record<string, Record<string, MDXEntry>> = {};

for (const p in mdxFiles) {
  try {
    const mod = mdxFiles[p];
    const contentIndex = p.split('/').indexOf('content');
    if (contentIndex === -1) continue;
    const rel = p.split('/').slice(contentIndex + 1); // e.g. [ '00-fundamentos-python', '01-instalacion.mdx' ]
    if (rel.length < 2) continue;
    const folder = rel[0];
    const filename = rel[1];
    const moduleSlug = folder.replace(/^\d+-/, '');
    const lessonMatch = filename.match(/^(\d+)/);
    const lessonNumber = lessonMatch ? String(parseInt(lessonMatch[1], 10)) : filename.replace(/\D/g, '');
    if (!mdxMap[moduleSlug]) mdxMap[moduleSlug] = {};
    mdxMap[moduleSlug][lessonNumber] = { component: mod.default ?? mod, frontmatter: (mod as any).frontmatter ?? (mod as any).meta ?? {} };
  } catch (err) {
    // ignore parse errors for unexpected files
  }
}

const mdxEntry = (mdxMap[module] && mdxMap[module][lesson]) ?? null;

const data = mdxEntry ? { title: mdxEntry.frontmatter?.title ?? `Lección ${lesson}`, content: null } : { title: `Lección ${lesson}`, content: 'Contenido no disponible' };
const MDXComponent = mdxEntry?.component ?? null;

const lessonNum = parseInt(lesson);
const prevLesson = lessonNum > 1 ? (lessonNum - 1).toString() : null;
const nextLesson = (lessonNum + 1).toString();
---

<BaseLayout title={data.title} description="Lección del curso">
  <div class="max-w-4xl mx-auto px-3 sm:px-4 md:px-6 py-6 sm:py-8">
    <a href={`/modules/${module}`} class="text-blue-600 hover:underline mb-4 inline-block text-sm sm:text-base">← Volver al módulo</a>

    <h1 class="text-xl sm:text-2xl md:text-3xl font-bold mb-4 sm:mb-6 leading-snug">{data.title}</h1>

    <article class="prose prose-slate max-w-none bg-white p-4 sm:p-6 md:p-8 rounded-xl border overflow-hidden">
      {MDXComponent ? <MDXComponent /> : <div set:html={data.content} />}
    </article>

    <div class="mt-6 sm:mt-8 pt-6 sm:pt-8 border-t flex justify-between items-center gap-4 text-sm sm:text-base">
      {prevLesson
        ? <a href={`/modules/${module}/${prevLesson}`} class="text-gray-600 hover:text-gray-900">← Anterior</a>
        : <span class="text-gray-300 select-none" aria-hidden="true">← Anterior</span>
      }
      <a href={`/modules/${module}/${nextLesson}`} class="text-blue-600 hover:text-blue-800 ml-auto">Siguiente →</a>
    </div>
  </div>
</BaseLayout>




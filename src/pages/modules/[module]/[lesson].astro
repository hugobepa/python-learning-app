---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export interface PathInfo {
  params: { module: string; lesson: string };
}

export async function getStaticPaths() {
  const modules = ['fundamentos-python', 'apis-fastapi', 'github-actions', 'python-n8n', 'python-docker', 'proyecto-integrador'];
  const paths: PathInfo[] = [];
  for (const m of modules) {
    for (let i = 1; i <= 6; i++) {
      paths.push({ params: { module: m, lesson: i.toString() } });
    }
  }
  return paths;
}

const { module, lesson } = Astro.params as { module: string; lesson: string };

// Build a map of available MDX lesson files under /src/content using an eager glob import.
const mdxFiles = import.meta.glob('/src/content/**/*.mdx', { eager: true }) as Record<string, any>;

type MDXEntry = { component: any; frontmatter?: Record<string, any> };
const mdxMap: Record<string, Record<string, MDXEntry>> = {};

for (const p in mdxFiles) {
  try {
    const mod = mdxFiles[p];
    const contentIndex = p.split('/').indexOf('content');
    if (contentIndex === -1) continue;
    const rel = p.split('/').slice(contentIndex + 1); // e.g. [ '00-fundamentos-python', '01-instalacion.mdx' ]
    if (rel.length < 2) continue;
    const folder = rel[0];
    const filename = rel[1];
    const moduleSlug = folder.replace(/^\d+-/, '');
    const lessonMatch = filename.match(/^(\d+)/);
    const lessonNumber = lessonMatch ? String(parseInt(lessonMatch[1], 10)) : filename.replace(/\D/g, '');
    if (!mdxMap[moduleSlug]) mdxMap[moduleSlug] = {};
    mdxMap[moduleSlug][lessonNumber] = { component: mod.default ?? mod, frontmatter: (mod as any).frontmatter ?? (mod as any).meta ?? {} };
  } catch (err) {
    // ignore parse errors for unexpected files
  }
}

const mdxEntry = (mdxMap[module] && mdxMap[module][lesson]) ?? null;

const data = mdxEntry ? { title: mdxEntry.frontmatter?.title ?? `Lección ${lesson}`, content: null } : { title: `Lección ${lesson}`, content: 'Contenido no disponible' };
const MDXComponent = mdxEntry?.component ?? null;

const moduleOrder = ['fundamentos-python', 'apis-fastapi', 'github-actions', 'python-n8n', 'python-docker', 'proyecto-integrador'];
const TOTAL_LESSONS = 6;
const lessonNum = parseInt(lesson);
const moduleIndex = moduleOrder.indexOf(module);

const prevLesson = lessonNum > 1 ? (lessonNum - 1).toString() : null;

let nextHref: string;
let nextLabel: string;
if (lessonNum < TOTAL_LESSONS) {
  nextHref = `/modules/${module}/${lessonNum + 1}`;
  nextLabel = 'Siguiente →';
} else if (moduleIndex >= 0 && moduleIndex < moduleOrder.length - 1) {
  nextHref = `/modules/${moduleOrder[moduleIndex + 1]}/1`;
  nextLabel = 'Siguiente módulo →';
} else {
  nextHref = '/dashboard';
  nextLabel = 'Ir al dashboard →';
}
---

<BaseLayout title={data.title} description="Lección del curso">
  <div id="lesson-top" class="max-w-4xl mx-auto px-3 sm:px-4 md:px-6 py-6 sm:py-8">
    <a href={`/modules/${module}`} class="text-blue-600 hover:underline mb-4 inline-block text-sm sm:text-base">← Volver al módulo</a>

    <h1 class="text-xl sm:text-2xl md:text-3xl font-bold mb-4 sm:mb-6 leading-snug">{data.title}</h1>

    <article class="lesson-content prose prose-slate max-w-none rounded-xl border bg-white p-4 sm:p-6 md:p-8 overflow-x-hidden">
      {MDXComponent ? <MDXComponent /> : <div set:html={data.content} />}
    </article>

    <!-- Numeric paginator — hidden on mobile -->
    <nav aria-label="Lecciones del módulo" class="hidden sm:flex items-center justify-center gap-1 mt-6 sm:mt-8">
      {Array.from({ length: TOTAL_LESSONS }, (_, i) => i + 1).map((n) => (
        n === lessonNum
          ? <span class="w-9 h-9 flex items-center justify-center rounded-full bg-blue-600 text-white font-bold text-sm" aria-current="page">{n}</span>
          : <a href={`/modules/${module}/${n}`} class="w-9 h-9 flex items-center justify-center rounded-full border-2 border-gray-200 text-gray-600 font-medium text-sm hover:border-blue-500 hover:text-blue-600 transition">{n}</a>
      ))}
    </nav>

    <div class="mt-4 pt-6 sm:pt-8 border-t flex justify-between items-center gap-4 text-sm sm:text-base">
      {prevLesson
        ? <a href={`/modules/${module}/${prevLesson}`} class="text-gray-600 hover:text-gray-900">← Anterior</a>
        : <span class="text-gray-300 select-none" aria-hidden="true">← Anterior</span>
      }
      <a href={nextHref} class="text-blue-600 hover:text-blue-800 ml-auto">{nextLabel}</a>
    </div>
  </div>
</BaseLayout>

<!-- Floating mobile back-to-top for lesson pages -->
<button id="lesson-back-to-top" aria-label="Volver arriba" class="fixed bottom-6 right-4 z-50 md:hidden w-12 h-12 bg-blue-600 text-white rounded-full shadow-lg flex items-center justify-center transition-opacity duration-200 opacity-0 pointer-events-none">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
</button>

<script>
  (function(){
    const btn = document.getElementById('lesson-back-to-top');
    const top = document.getElementById('lesson-top');
    if(!btn || !top) return;
    const showAfter = 200;
    const toggle = () => {
      if(window.scrollY > showAfter) {
        btn?.classList.remove('opacity-0','pointer-events-none');
      } else {
        btn?.classList.add('opacity-0','pointer-events-none');
      }
    };
    window.addEventListener('scroll', toggle, { passive: true });
    btn.addEventListener('click', ()=> top.scrollIntoView({ behavior: 'smooth' }));
    toggle();
  })();
</script>




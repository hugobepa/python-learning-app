---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  {
    slug: 'fundamentos-python',
    title: 'Fundamentos Python',
    description: 'Variables, funciones, estructuras de datos y POO esencial',
    badgeColor: 'bg-blue-500',
    xp: '+550 XP',
  },
  {
    slug: 'apis-fastapi',
    title: 'APIs con FastAPI',
    description: 'Crea APIs REST profesionales con validación y autenticación',
    badgeColor: 'bg-green-500',
    xp: '+600 XP',
  },
  {
    slug: 'github-actions',
    title: 'GitHub Actions',
    description: 'Automatiza CI/CD para tus proyectos Python',
    badgeColor: 'bg-purple-500',
    xp: '+500 XP',
  },
  {
    slug: 'python-n8n',
    title: 'Python + n8n',
    description: 'Automatiza workflows integrando Python con n8n',
    badgeColor: 'bg-orange-500',
    xp: '+500 XP',
  },
  {
    slug: 'python-docker',
    title: 'Python + Docker',
    description: 'Conteneriza tus aplicaciones Python para producción',
    badgeColor: 'bg-sky-500',
    xp: '+600 XP',
  },
  {
    slug: 'proyecto-integrador',
    title: 'Proyecto Integrador',
    description: 'Combina API, Docker, GitHub Actions y n8n',
    badgeColor: 'bg-slate-700',
    xp: '+700 XP',
  },
];
---

<BaseLayout title="Dashboard">
  <div id="dashboard-top" class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">👋 ¡Bienvenido!</h1>
    <p class="text-gray-600 mb-8">Continúa donde lo dejaste y alcanza tus metas de hoy.</p>
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-blue-500 p-6 rounded-xl text-white shadow-lg">
        <p class="text-2xl font-bold">0</p>
        <p class="text-sm opacity-80">XP Total</p>
      </div>
      <div class="bg-orange-500 p-6 rounded-xl text-white shadow-lg">
        <p class="text-2xl font-bold">0</p>
        <p class="text-sm opacity-80">Días Racha</p>
      </div>
      <div class="bg-white p-6 rounded-xl shadow border">
        <p class="text-2xl font-bold text-gray-900">0/36</p>
        <p class="text-sm text-gray-500">Lecciones</p>
      </div>
      <div class="bg-green-500 p-6 rounded-xl text-white shadow-lg">
        <p class="text-2xl font-bold">0/100</p>
        <p class="text-sm opacity-80">Meta Diaria</p>
      </div>
    </div>

    <!-- Modules -->
    <h2 class="text-2xl font-bold mb-4">Módulos</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {modules.map((module) => (
        <a href={`${import.meta.env.BASE_URL}modules/${module.slug}`} class="p-6 bg-white rounded-xl border-2 border-gray-200 hover:border-blue-500 transition shadow-sm hover:shadow-md">
          <div class={`w-12 h-12 ${module.badgeColor} rounded-lg flex items-center justify-center text-white font-bold mb-4`}>6</div>
          <h3 class="font-bold text-lg mb-2">{module.title}</h3>
          <p class="text-sm text-gray-500 mb-4">{module.description}</p>
          <div class="flex justify-between items-center gap-3">
            <span class="text-xs text-gray-500">6 lecciones</span>
            <span class="text-xs font-bold text-blue-600">{module.xp}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Floating back-to-top button for mobile -->
    <a
      id="back-to-top"
      href="#dashboard-top"
      aria-label="Subir al inicio"
      class="fixed bottom-6 right-4 z-50 md:hidden w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-blue-700 transition-opacity duration-200 opacity-0 pointer-events-none"
    >
      ↑
    </a>

    <script>
      (function () {
        const btn = document.getElementById('back-to-top');
        if (!btn) return;
        const showAfter = 200;
        function onScroll() {
          if (window.scrollY > showAfter) {
              btn?.classList.remove('opacity-0', 'pointer-events-none');
              btn?.classList.add('opacity-100');
            } else {
              btn?.classList.add('opacity-0', 'pointer-events-none');
              btn?.classList.remove('opacity-100');
            }
        }
        // initial check
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </div>
</BaseLayout>
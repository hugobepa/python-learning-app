---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Dashboard">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">👋 ¡Bienvenido!</h1>
    <p class="text-gray-600 mb-8">Continúa donde lo dejaste y alcanza tus metas de hoy.</p>
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-blue-500 p-6 rounded-xl text-white shadow-lg">
        <p class="text-2xl font-bold">0</p>
        <p class="text-sm opacity-80">XP Total</p>
      </div>
      <div class="bg-orange-500 p-6 rounded-xl text-white shadow-lg">
        <p class="text-2xl font-bold">0</p>
        <p class="text-sm opacity-80">Días Racha</p>
      </div>
      <div class="bg-white p-6 rounded-xl shadow border">
        <p class="text-2xl font-bold text-gray-900">0/36</p>
        <p class="text-sm text-gray-500">Lecciones</p>
      </div>
      <div class="bg-green-500 p-6 rounded-xl text-white shadow-lg">
        <p class="text-2xl font-bold">0/100</p>
        <p class="text-sm opacity-80">Meta Diaria</p>
      </div>
    </div>

    <!-- Modules -->
    <h2 class="text-2xl font-bold mb-4">Módulos</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/modules/fundamentos-python" class="p-6 bg-white rounded-xl border-2 border-gray-200 hover:border-blue-500 transition shadow-sm hover:shadow-md">
        <div class="w-12 h-12 bg-blue-500 rounded-lg flex items-center justify-center text-white font-bold mb-4">6</div>
        <h3 class="font-bold text-lg mb-2">Fundamentos Python</h3>
        <p class="text-sm text-gray-500 mb-4">Variables, funciones, estructuras de datos y POO esencial</p>
        <div class="flex justify-between items-center">
          <span class="text-xs text-gray-500">6 lecciones</span>
          <span class="text-xs font-bold text-blue-600">+550 XP</span>
        </div>
      </a>
      
      <a href="/modules/apis-fastapi" class="p-6 bg-white rounded-xl border-2 border-gray-200 hover:border-blue-500 transition shadow-sm hover:shadow-md">
        <div class="w-12 h-12 bg-green-500 rounded-lg flex items-center justify-center text-white font-bold mb-4">6</div>
        <h3 class="font-bold text-lg mb-2">APIs con FastAPI</h3>
        <p class="text-sm text-gray-500 mb-4">Crea APIs REST profesionales con validación y autenticación</p>
        <div class="flex justify-between items-center">
          <span class="text-xs text-gray-500">6 lecciones</span>
          <span class="text-xs font-bold text-blue-600">+600 XP</span>
        </div>
      </a>
      
      <a href="/modules/github-actions" class="p-6 bg-white rounded-xl border-2 border-gray-200 hover:border-blue-500 transition shadow-sm hover:shadow-md">
        <div class="w-12 h-12 bg-purple-500 rounded-lg flex items-center justify-center text-white font-bold mb-4">6</div>
        <h3 class="font-bold text-lg mb-2">GitHub Actions</h3>
        <p class="text-sm text-gray-500 mb-4">Automatiza CI/CD para tus proyectos Python</p>
        <div class="flex justify-between items-center">
          <span class="text-xs text-gray-500">6 lecciones</span>
          <span class="text-xs font-bold text-blue-600">+500 XP</span>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
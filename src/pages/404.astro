---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página No Encontrada" description="Error 404">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-white to-purple-50 px-4">
    <div class="max-w-2xl w-full text-center">
      <!-- Error Code -->
      <div class="mb-8">
        <h1 class="text-9xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600">
          404
        </h1>
      </div>
      
      <!-- Icono Python triste -->
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-24 h-24 bg-gray-100 rounded-full">
          <span class="text-6xl">🐍</span>
        </div>
      </div>
      
      <!-- Mensaje -->
      <h2 class="text-3xl font-bold text-gray-900 mb-4">
        ¡Ups! Página no encontrada
      </h2>
      
      <p class="text-lg text-gray-600 mb-8 max-w-md mx-auto">
        La página que buscas ha sido movida, eliminada o nunca existió. 
        No te preocupes, ¡es parte del aprendizaje!
      </p>
      
      <!-- XP Perdido (Gamificación) -->
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-8 max-w-sm mx-auto">
        <p class="text-yellow-800 text-sm">
          ⚠️ <strong>XP Perdido:</strong> 10 XP por navegar a página inexistente
        </p>
        <p class="text-yellow-600 text-xs mt-1">
          💡 Consejo: Usa el menú de navegación para explorar el contenido disponible
        </p>
      </div>
      
      <!-- Botones de Acción -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a 
          href="/" 
          class="bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-bold hover:bg-blue-700 transition shadow-lg"
        >
          🏠 Ir al Inicio
        </a>
        <a 
          href="/modules" 
          class="bg-white text-blue-600 border-2 border-blue-600 px-8 py-4 rounded-lg text-lg font-bold hover:bg-blue-50 transition"
        >
          📚 Ver Módulos
        </a>
        <a 
          href="/dashboard" 
          class="bg-white text-gray-700 border-2 border-gray-300 px-8 py-4 rounded-lg text-lg font-bold hover:bg-gray-50 transition"
        >
          📊 Dashboard
        </a>
      </div>
      
      <!-- Enlaces Rápidos -->
      <div class="bg-white rounded-xl border p-6 max-w-lg mx-auto">
        <h3 class="font-bold text-gray-900 mb-4">🔗 Enlaces Rápidos</h3>
        <div class="grid grid-cols-2 gap-3 text-sm">
          <a href="/modules/fundamentos-python" class="text-blue-600 hover:underline text-left">
            → Fundamentos Python
          </a>
          <a href="/modules/apis-fastapi" class="text-blue-600 hover:underline text-left">
            → APIs con FastAPI
          </a>
          <a href="/modules/github-actions" class="text-blue-600 hover:underline text-left">
            → GitHub Actions
          </a>
          <a href="/modules/python-docker" class="text-blue-600 hover:underline text-left">
            → Python + Docker
          </a>
        </div>
      </div>
      
      <!-- Reportar Error -->
      <div class="mt-8 text-sm text-gray-500">
        <p>¿Crees que esto es un error?</p>
        <a href="https://github.com/hugobepa/python-learning-app/issues" class="text-blue-600 hover:underline" target="_blank">
          Repórtalo en GitHub
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
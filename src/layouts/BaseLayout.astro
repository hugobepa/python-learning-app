---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Aprende Python profesional con APIs, n8n y Docker' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Python Learning App</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <!-- Navegación -->
    <nav class="bg-white border-b border-gray-200 px-6 py-4 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href="/" class="font-bold text-xl text-blue-600 flex items-center gap-2">
          🐍 PythonEdu
        </a>
        <div class="hidden md:flex gap-6">
          <a href="/dashboard" class="hover:text-blue-600 transition">Dashboard</a>
          <a href="/modules" class="hover:text-blue-600 transition">Módulos</a>
          <a href="/quiz" class="hover:text-blue-600 transition">Quiz</a>
        </div>
      </div>
    </nav>
    
    <!-- Contenido Principal -->
    <main class="min-h-screen">
      <slot />
    </main>
    
    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-8 mt-20">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <p>© 2026 Python Learning App - Hecho con ❤️ para la comunidad Python</p>
      </div>
    </footer>
  </body>
</html>